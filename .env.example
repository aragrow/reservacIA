# Path to the SQLite database file. Directory must exist.
DATABASE_PATH=./data/reservations.db

# HS256 signing secret. Generate with: openssl rand -hex 32
JWT_SECRET=change-me-to-a-32-byte-random-hex-string

# Access token TTL in minutes (default 1440 = 24h)
JWT_TTL_MINUTES=1440

# Refresh token TTL in days (default 180 ≈ 6 months). Rotates on each /auth/refresh,
# so calling refresh at least once per 6 months keeps the session alive.
REFRESH_TTL_DAYS=180

# The client identity the agent will present
CLIENT_ID=agent-client
CLIENT_SECRET=change-me-to-a-strong-secret

# Comma-separated CIDR ranges allowed to reach the API. Use /32 for single IPs.
# Example: ALLOWED_IPS=127.0.0.1/32,10.0.0.0/24
ALLOWED_IPS=127.0.0.1/32

# Localization. Defaults below assume the restaurant is in Spain. Override
# per deployment if needed.
LOCALE=es_ES
TIMEZONE=Europe/Madrid              # IANA name; handles CET/CEST DST automatically
DATE_FORMAT="%d/%m/%Y"              # 25/04/2026
TIME_FORMAT="%H:%M"                 # 19:30 (24-hour)
DATETIME_FORMAT="%d/%m/%Y %H:%M"    # 25/04/2026 19:30

# Notifications (transactional customer messages on reservation lifecycle).
# v1 supports 'console' (log only) and 'disabled'. Twilio impl pending.
NOTIFIER=console
REMINDER_LEAD_HOURS=24
NOTIFICATION_WORKER_INTERVAL_SECONDS=30
NOTIFICATION_MAX_ATTEMPTS=5
# Kill switch — when true, lifecycle notifications (created/updated/cancelled/
# reminder) are dropped: not enqueued, not sent. Agent-driven `custom` messages
# (POST /notifications) are exempt so the agent's outbound activity stays
# auditable. Flip back to false to resume lifecycle messaging.
SUPPRESS_NOTIFICATIONS=false

# Local dev convenience. When true (and only from a loopback IP):
#   - /_debug/dev-token issues a fresh access token with no credentials
#   - /docs auto-fills the Authorize dialog on page load
#   - /auth/token + /auth/refresh examples are pre-populated from .env
# MUST be false in production.
LOCAL_MODE=false
